---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="UNO" description="hi" />
		<style>
			main {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 5rem 1rem;
				text-align: center;
			}

			.me {
				width: 150px;
				height: 150px;
				border-radius: 50%;
				border: 3px solid #22c55e;
				margin-bottom: 2rem;
				/* Teknik center paksa */
				display: block;
				margin-inline: auto;
				object-fit: cover;
			}

			h1 {
				font-family: monospace;
				font-size: 1.5rem;
				color: #166534;
			}

			.links {
				margin-top: 2rem;
				display: flex;
				gap: 1.5rem;
			}

			.links a {
				color: #22c55e;
				text-decoration: none;
				font-weight: bold;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<img src="/me.png" alt="me" class="me" />
			
			<h1>hi</h1>

			<div class="links">
				<a href="/blog">blog</a>
				<a href="/about">about</a>
			</div>
		</main>
		<Footer />
	</body>
</html>
